# SharpClaw configuration
# Copy to .env and fill in your values.
# Variable names use .NET's __ (double-underscore) convention for hierarchical config.

# API key to protect the SharpClaw API (optional — leave blank to disable)
SharpClaw__ApiKey=

# Anthropic API key (required for the generic LLM service)
SharpClaw__AnthropicApiKey=

# GitHub personal access token (required for the Copilot SDK service)
SharpClaw__GitHubToken=

# Workspace root directory (optional — defaults to {DataRoot}/workspace)
# Set this to a path under your home directory to use your own files.
SharpClaw__WorkspaceRoot=

# ── Telegram Bot ──
# Bot token from @BotFather
Telegram__BotToken=

# Comma-separated Telegram usernames allowed to use the bot (without @, empty = all)
Telegram__AllowedUsers=

